pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Baixa o código do repositório
                checkout scm
            }
        }

        stage('Instalar Dependências') {
            steps {
                // Entra na pasta do backend para instalar os pacotes do Node/NestJS
                dir('backend') {
                    sh 'npm install'
                }
            }
        }

        stage('Executar Testes') {
            steps {
                dir('backend') {
                    // Executa os testes para validar os 90% de cobertura
                    sh 'npm run test:cov'
                }
            }
            post {
                always {
                    // REGRA ATENDIDA: Guarda o relatório de testes como Artefato
                    archiveArtifacts artifacts: 'backend/coverage/**', allowEmptyArchive: true
                }
            }
        }

        stage('Build e Empacotamento') {
            steps {
                dir('backend') {
                    // Realiza o build da aplicação (gera a pasta dist)
                    sh 'npm run build'
                }
            }
            post {
                success {
                    // REGRA ATENDIDA: Guarda o pacote gerado (build) como Artefato
                    archiveArtifacts artifacts: 'backend/dist/**', allowEmptyArchive: true
                }
            }
        }

        stage('Notificar por E-mail') {
            steps {
                // Injeta a variável de ambiente segura cadastrada no painel do Jenkins
                withCredentials([
                    string(credentialsId: 'EMAIL_DESTINO', variable: 'EMAIL_DESTINO')
                ]) {
                    // REGRA ATENDIDA: Chama o script de notificação
                    sh 'node scripts/notify-email.js'
                }
            }
        }
    }
}